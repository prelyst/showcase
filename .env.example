# Feature flags
# Set to true only after Prisma migrations and seed have already been run successfully for the target environment.
SHOWCASE_ENABLE_DB=false
# Temporary one-shot hook. Set to true only for the first schema creation deploy, then remove or set back to false.
SHOWCASE_SCHEMA_ONCE=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / Postgres
DATABASE_URL=
# Optional dedicated direct connection if you later split pooled/direct connections for migrations
DIRECT_URL=
