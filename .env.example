# Feature flags
# Set to true when you want build/deploy to automatically run Prisma deploy + seed and enable DB-backed Showcase pages.
SHOWCASE_ENABLE_DB=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / Postgres
DATABASE_URL=
# Optional dedicated direct connection if you later split pooled/direct connections for migrations
DIRECT_URL=
