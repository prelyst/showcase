# Feature flags
# Set to true only after Prisma migrations and seed have already been run successfully for the target environment.
SHOWCASE_ENABLE_DB=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / Postgres
# Use pooled connection for app/runtime traffic.
DATABASE_URL=
# Use direct connection for Prisma migrations.
DIRECT_URL=

# Security notes
# - Never commit real Supabase or database secrets.
# - Rotate any secrets that were pasted into chat or logs during debugging.
# - Prefer separate production/dev credentials.
