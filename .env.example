# Feature flags
# Set to true only after Prisma migrations and seed have already been run successfully for the target environment.
SHOWCASE_ENABLE_DB=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / Postgres
# Use pooled connection for app/runtime traffic.
DATABASE_URL=
# Use direct connection for Prisma migrations.
DIRECT_URL=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth provider setup (optional in local/dev, required for real connected-account flows)
OAUTH_X_CLIENT_ID=
OAUTH_X_CLIENT_SECRET=
OAUTH_THREADS_CLIENT_ID=
OAUTH_THREADS_CLIENT_SECRET=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_INSTAGRAM_CLIENT_ID=
OAUTH_INSTAGRAM_CLIENT_SECRET=
OAUTH_YOUTUBE_CLIENT_ID=
OAUTH_YOUTUBE_CLIENT_SECRET=
SHOWCASE_OAUTH_STATE_SECRET=

# Security notes
# - Never commit real Supabase, database, or OAuth provider secrets.
# - Rotate any secrets that were pasted into chat or logs during debugging.
# - Prefer separate production/dev credentials.
# - OAuth callbacks expect NEXT_PUBLIC_APP_URL to match your deployed origin.
